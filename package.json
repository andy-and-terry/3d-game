{
  "name": "3d-game",
  "version": "0.1.0",
  "description": "Procedural 3D game with Electron + Babylon.js",
  "private": true,
  "type": "commonjs",
  "main": "src/main.js",
  "scripts": {
    "node:check-lts": "node ./tools/check-node-lts.js",
    "start": "npm run node:check-lts && electron .",
    "start:dev": "npm run node:check-lts && electron .",
    "dev": "npm run start:dev",
    "build": "electron-builder",
    "build:win": "npm run node:check-lts && electron-builder --win nsis",
    "test": "node --test"
  },
  "dependencies": {
    "@babylonjs/core": "^6.0.0",
    "@babylonjs/loaders": "^6.0.0"
  },
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.andy-and-terry.3d-game",
    "productName": "3D Game",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "gen/**/*",
      "assets/**/*",
      "tools/**/*",
      "data/**/*",
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "tools/installer/include.nsh"
    }
  }
}
